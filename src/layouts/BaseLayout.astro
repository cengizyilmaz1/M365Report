---
import "@/styles/global.css";
import SiteFooter from "@/components/site/SiteFooter.astro";
import SiteHeader from "@/components/site/SiteHeader.astro";
import { withBase } from "@/lib/paths";
import { siteConfig } from "@/lib/site";

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  canonicalPath?: string;
  keywords?: string[];
  pageType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = siteConfig.defaultDescription,
  noindex = false,
  canonicalPath = Astro.url.pathname,
  keywords = siteConfig.defaultKeywords,
  pageType = "website",
  publishedTime,
  modifiedTime,
  structuredData
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, Astro.site ?? Astro.url).toString();
const structuredDataEntries = structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Sora:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" type="image/x-icon" href={withBase("/favicon.ico")} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="author" content={siteConfig.authorName} />
    <meta name="theme-color" content="#0ea5e9" />
    <meta name="generator" content={Astro.generator} />
    <meta name="application-name" content={siteConfig.name} />

    <link rel="stylesheet" href={withBase("/assets/brand-shell.css")} />
    <link rel="canonical" href={canonicalUrl} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {!noindex && <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={pageType} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteConfig.socialHandle} />
    <meta name="twitter:creator" content={siteConfig.socialHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {structuredDataEntries.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body class="brand-shell shell-grid text-ink-950 antialiased">
    <SiteHeader />
    <main class="pb-16 md:pb-24">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
