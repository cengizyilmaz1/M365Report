---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/lib/site";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Login | M365 Tenant Reporter",
  url: `${siteConfig.siteUrl}${siteConfig.loginPath}`
};
---

<BaseLayout
  title="Login | M365 Tenant Reporter"
  description="Sign in with Microsoft Entra to generate read-only Microsoft 365 tenant reports."
  keywords={[
    "m365 tenant reporter login",
    "microsoft entra delegated login",
    "m365report login page"
  ]}
  noindex={true}
  structuredData={structuredData}
>
  <section class="flex min-h-[calc(100vh-10rem)] items-center justify-center py-12">
    <div class="page-frame max-w-md">
      <div class="hero-glow glass-panel rounded-3xl p-8 text-center animate-fade-up">
        <div class="mb-6 flex justify-center">
          <span class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-sky-500 to-violet-500 shadow-xl shadow-sky-500/25">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
              <polyline points="9 22 9 12 15 12 15 22" />
            </svg>
          </span>
        </div>

        <h1 class="text-2xl font-bold tracking-tight text-ink-950" style="font-family: var(--font-display);">
          {siteConfig.name}
        </h1>
        <p class="mt-2 text-sm text-ink-600">
          Sign in with your Microsoft account to generate tenant reports.
        </p>

        <div class="mt-8">
          <a
            href="/app"
            class="btn-primary w-full justify-center py-3.5 text-[15px]"
            id="login-redirect"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
              <polyline points="10 17 15 12 10 7" />
              <line x1="15" y1="12" x2="3" y2="12" />
            </svg>
            Continue with Microsoft Entra
          </a>
        </div>

        <div class="divider my-6"></div>

        <div class="flex items-center justify-center gap-4 text-xs text-ink-500">
          <span class="flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
              <circle cx="12" cy="12" r="3" />
            </svg>
            Read-only
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            Zero storage
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            Local export
          </span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
