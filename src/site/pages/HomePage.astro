---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionBlock from "@/components/site/SectionBlock.astro";
import HomeHero from "@/site/partials/HomeHero.astro";
import CapabilityGrid from "@/site/partials/CapabilityGrid.astro";
import GuidePreviewGrid from "@/site/partials/GuidePreviewGrid.astro";
import { organizationProfiles, siteConfig } from "@/lib/site";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: siteConfig.name,
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web browser",
    description: siteConfig.defaultDescription,
    url: siteConfig.siteUrl
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteConfig.name,
    url: siteConfig.siteUrl
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: siteConfig.name,
    url: siteConfig.siteUrl,
    founder: {
      "@type": "Person",
      name: siteConfig.authorName,
      url: siteConfig.authorUrl
    },
    sameAs: organizationProfiles
  }
];
---

<BaseLayout
  title={`${siteConfig.name} | Read-only Microsoft 365 reporting`}
  description="Read-only Microsoft 365 tenant reporting with a clean login flow, browser-only Graph collection, and local export generation."
  keywords={[
    ...siteConfig.defaultKeywords,
    "microsoft 365 reporting platform",
    "zero-storage saas reporting",
    "browser-only microsoft graph reporting"
  ]}
  structuredData={structuredData}
>
  <HomeHero />

  <SectionBlock
    title="Everything important is available from one clean login route"
    description="The product site explains the platform, but `/login` is the main operational entry point for sign-in, report generation, and export."
  >
    <div class="grid gap-4 md:grid-cols-3">
      <article class="fine-border card-hover rounded-[1.6rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Sign in</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Use Microsoft Entra delegated access from the single trusted route: <strong>/login</strong>.</p>
      </article>
      <article class="fine-border card-hover rounded-[1.6rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Generate</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Collect users, licenses, groups, and mailbox insights inside the current browser session.</p>
      </article>
      <article class="fine-border card-hover rounded-[1.6rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Export</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Download clean CSV, JSON, Excel, or HTML files without keeping a persistent tenant dataset.</p>
      </article>
    </div>
  </SectionBlock>

  <SectionBlock
    title="Core reports"
    description="The product focuses on inventory and visibility. It is intentionally read-only and avoids remediation features."
  >
    <CapabilityGrid />
  </SectionBlock>

  <SectionBlock
    title="Feature guides and walkthroughs"
    description="The Jekyll blog explains each report in a search-friendly format, including exports, license availability, group counts, and shared mailboxes."
  >
    <GuidePreviewGrid />
  </SectionBlock>
</BaseLayout>
