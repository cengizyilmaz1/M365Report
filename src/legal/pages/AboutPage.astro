---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import SectionBlock from "@/components/site/SectionBlock.astro";
import { siteConfig } from "@/lib/site";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About | M365 Tenant Reporter",
  url: `${siteConfig.siteUrl}${siteConfig.aboutPath}`,
  description: "Learn what M365 Tenant Reporter does, who it is for, and why it keeps Microsoft 365 reporting read-only and session-based."
};
---

<BaseLayout
  title="About | M365 Tenant Reporter"
  description="Learn what M365 Tenant Reporter does, who it is for, and why it keeps Microsoft 365 reporting read-only and session-based."
  keywords={[
    "about m365 tenant reporter",
    "microsoft 365 reporting architecture",
    "zero-storage reporting product",
    "microsoft graph reporting tool"
  ]}
  structuredData={structuredData}
>
  <PageHero
    eyebrow="About"
    title="A focused reporting product for Microsoft 365 teams."
    body="M365 Tenant Reporter is built for visibility, not remediation. Sign in, collect a report snapshot, review the data, and export what you need."
  />

  <SectionBlock title="What the product does">
    <div class="grid gap-4 md:grid-cols-3">
      <article class="fine-border card-hover rounded-2xl bg-white p-6">
        <div class="icon-container bg-sky-500/10 text-sky-500 mb-4">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
          </svg>
        </div>
        <h3 class="text-base font-bold text-ink-950">Inventory reporting</h3>
        <p class="mt-2 text-sm leading-7 text-ink-600">Review total users, licensed users, unlicensed users, groups, mailbox purpose, and license capacity.</p>
      </article>
      <article class="fine-border card-hover rounded-2xl bg-white p-6">
        <div class="icon-container bg-mint-500/10 text-mint-500 mb-4">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
        </div>
        <h3 class="text-base font-bold text-ink-950">Local exports</h3>
        <p class="mt-2 text-sm leading-7 text-ink-600">Download report outputs as CSV, JSON, Excel, or HTML directly from the browser.</p>
      </article>
      <article class="fine-border card-hover rounded-2xl bg-white p-6">
        <div class="icon-container bg-violet-500/10 text-violet-500 mb-4">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
        </div>
        <h3 class="text-base font-bold text-ink-950">Read-only safety</h3>
        <p class="mt-2 text-sm leading-7 text-ink-600">The app does not assign licenses, change tenant settings, or run remediation actions.</p>
      </article>
    </div>
  </SectionBlock>

  <SectionBlock title="How the product is meant to be used">
    <div class="space-y-4 text-base leading-8 text-ink-600">
      <p>The main user flow is simple: open <strong class="text-ink-800">{`${siteConfig.domain}/login`}</strong>, complete Microsoft Entra sign-in, generate a fresh report snapshot, then export what you need.</p>
      <p>The public site and blog explain the product, but the operational experience is centered around that single login route so it stays clear for admins and end users.</p>
    </div>
  </SectionBlock>
</BaseLayout>
