---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AppEntry from "@/features/app/AppEntry";
import { siteConfig } from "@/lib/site";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Login | M365 Tenant Reporter",
  url: `${siteConfig.siteUrl}${siteConfig.loginPath}`
};
---

<BaseLayout
  title="Login | M365 Tenant Reporter"
  description="Use the single login route to sign in with Microsoft Entra, generate a tenant report snapshot, and export the result."
  keywords={[
    "m365 tenant reporter login",
    "microsoft entra delegated login",
    "m365report login page"
  ]}
  noindex={true}
  structuredData={structuredData}
>
  <section class="section-space pb-4">
    <div class="page-frame">
      <div class="hero-glow glass-panel rounded-3xl p-8 md:p-10">
        <div class="grid gap-8 lg:grid-cols-[1fr_1fr] lg:items-center">
          <div class="space-y-5 animate-fade-up">
            <span class="badge badge-sky">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
              Secure login
            </span>

            <h1 class="text-balance text-3xl font-bold leading-tight tracking-tight text-ink-950 md:text-4xl lg:text-[2.75rem]" style="font-family: var(--font-display);">
              Sign in, generate reports, and export from <span class="gradient-text">one clean page.</span>
            </h1>

            <p class="max-w-lg text-base leading-8 text-ink-600">
              This is the main entry point for M365 Tenant Reporter. Microsoft Entra sign-in, in-session report generation, and local exports all happen right here.
            </p>

            <div class="flex flex-wrap gap-2 pt-1">
              <span class="badge badge-neutral">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
                Read-only
              </span>
              <span class="badge badge-neutral">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>
                Session-only
              </span>
              <span class="badge badge-neutral">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
                Local exports
              </span>
            </div>
          </div>

          <div class="space-y-3 animate-fade-up" style="animation-delay: 0.1s;">
            <div class="fine-border rounded-2xl bg-white/80 p-5">
              <div class="flex items-start gap-4">
                <div class="icon-container bg-sky-500/10 text-sky-500">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                  </svg>
                </div>
                <div>
                  <h2 class="text-sm font-bold text-ink-950">Generate reports</h2>
                  <p class="mt-1 text-sm leading-6 text-ink-600">Collect overview, users, licenses, groups, mailbox purpose, and export-ready tables from Microsoft Graph.</p>
                </div>
              </div>
            </div>

            <div class="fine-border rounded-2xl bg-white/80 p-5">
              <div class="flex items-start gap-4">
                <div class="icon-container bg-mint-500/10 text-mint-500">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  </svg>
                </div>
                <div>
                  <h2 class="text-sm font-bold text-ink-950">Keep data in-session</h2>
                  <p class="mt-1 text-sm leading-6 text-ink-600">No persistent tenant storage. Clear session, refresh, sign out, or close to remove all in-memory data.</p>
                </div>
              </div>
            </div>

            <div class="fine-border rounded-2xl bg-white/80 p-5">
              <div class="flex items-start gap-4">
                <div class="icon-container bg-violet-500/10 text-violet-500">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                  </svg>
                </div>
                <div>
                  <h2 class="text-sm font-bold text-ink-950">Clear operational limits</h2>
                  <p class="mt-1 text-sm leading-6 text-ink-600">When a workload is unavailable due to roles, licensing, or browser constraints, you see a clear explanation.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="page-frame mt-6">
      <AppEntry client:load />
    </div>
  </section>
</BaseLayout>
