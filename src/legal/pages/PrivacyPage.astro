---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import SectionBlock from "@/components/site/SectionBlock.astro";
import { siteConfig } from "@/lib/site";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "PrivacyPolicy",
  name: "Privacy | M365 Tenant Reporter",
  url: `${siteConfig.siteUrl}${siteConfig.privacyPath}`
};
---

<BaseLayout
  title="Privacy | M365 Tenant Reporter"
  description="Review how M365 Tenant Reporter handles delegated sign-in, browser-only report generation, and zero-storage exports."
  keywords={[
    "m365 privacy policy",
    "browser-only microsoft graph reporting",
    "zero-storage privacy model"
  ]}
  structuredData={structuredData}
>
  <PageHero
    eyebrow="Privacy"
    title="The application is built to minimize retained tenant data."
    body="Microsoft Graph collection happens in the browser after delegated sign-in. The runtime keeps report data in memory for the active session and the user controls any exported files."
  />

  <SectionBlock title="What is stored">
    <div class="grid gap-4 md:grid-cols-2">
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Authentication state</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">MSAL stores only the session data needed to maintain the delegated login flow in sessionStorage.</p>
      </article>
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Public runtime configuration</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">The static site ships public client configuration and route settings, but no tenant report content or backend secret material.</p>
      </article>
    </div>
  </SectionBlock>

  <SectionBlock title="What is not stored">
    <div class="grid gap-4 md:grid-cols-2">
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">No server-side tenant warehouse</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Users, groups, licenses, mailboxes, and activity rows are not copied to a backend database by the product.</p>
      </article>
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">No persistent browser cache for reports</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">The reporting snapshot is not persisted to localStorage or IndexedDB. Clearing the session removes the in-memory state.</p>
      </article>
    </div>
  </SectionBlock>
</BaseLayout>
