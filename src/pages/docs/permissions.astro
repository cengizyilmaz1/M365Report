---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import SectionBlock from "@/components/site/SectionBlock.astro";
import { withBase } from "@/lib/paths";
import { siteConfig } from "@/lib/site";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Overview",
        item: siteConfig.siteUrl
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Permissions",
        item: `${siteConfig.siteUrl}/docs/permissions`
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "Does the app request write permissions?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "No. The delegated Microsoft Graph scopes are read-focused and the product is designed for reporting only."
        }
      },
      {
        "@type": "Question",
        name: "When is AuditLog.Read.All needed?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "AuditLog.Read.All is optional and only needed when the operator wants last sign-in visibility in the login-based reporting flow."
        }
      }
    ]
  }
];
---

<BaseLayout
  title="Permissions | M365 Tenant Reporter"
  description="Understand the delegated Microsoft Graph scopes used by M365 Tenant Reporter."
  keywords={[
    "m365 delegated permissions",
    "microsoft graph consent guide",
    "reports.read.all explanation"
  ]}
  structuredData={structuredData}
>
  <PageHero
    eyebrow="Permissions"
    title="Delegated Microsoft Graph permissions are grouped by reporting capability."
    body="Core reporting scopes are requested up front, reporting scopes enable usage analytics, and advanced audit scopes are requested only when the operator enables optional last sign-in insight."
  />

  <SectionBlock title="Permission groups">
    <div class="grid gap-4 md:grid-cols-3">
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold">Core</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">openid, profile, email, User.Read, User.Read.All, GroupMember.Read.All, LicenseAssignment.Read.All, MailboxSettings.Read</p>
      </article>
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold">Reports</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Reports.Read.All for Office 365 active users, Teams activity, mailbox usage, and OneDrive usage.</p>
      </article>
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold">Advanced audit</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">AuditLog.Read.All is optional and only needed when last sign-in summaries are explicitly enabled.</p>
      </article>
    </div>
  </SectionBlock>

  <SectionBlock title="How to explain the scope model internally">
    <div class="grid gap-4 md:grid-cols-2">
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Core reporting stays read-only</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">
          The core scope set exists so the app can inventory users, groups, license assignments, and mailbox purpose without crossing into management or remediation.
        </p>
      </article>
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Optional scopes stay optional</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">
          Usage and audit capabilities are separated so operators can keep the initial consent boundary tight when they only need inventory reporting.
        </p>
      </article>
    </div>
  </SectionBlock>

  <SectionBlock title="Related reading">
    <div class="grid gap-4 md:grid-cols-2">
      <a href={withBase("/blog/permissions-consent-guide")} class="fine-border rounded-[1.5rem] bg-white p-6 transition hover:border-ink-900/16 hover:bg-sand-100">
        <h3 class="text-lg font-semibold text-ink-950">Full permissions and consent guide</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Read the longer explanation of why each delegated scope exists and when optional audit access should remain off.</p>
      </a>
      <a href={withBase(siteConfig.loginPath)} class="fine-border rounded-[1.5rem] bg-white p-6 transition hover:border-ink-900/16 hover:bg-sand-100">
        <h3 class="text-lg font-semibold text-ink-950">Open the consent flow</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Send users to the login page when they are ready to review scopes and authorize a reporting session.</p>
      </a>
    </div>
  </SectionBlock>
</BaseLayout>
