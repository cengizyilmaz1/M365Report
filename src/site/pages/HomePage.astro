---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionBlock from "@/components/site/SectionBlock.astro";
import HomeHero from "@/site/partials/HomeHero.astro";
import CapabilityGrid from "@/site/partials/CapabilityGrid.astro";
import GuidePreviewGrid from "@/site/partials/GuidePreviewGrid.astro";
import { organizationProfiles, siteConfig } from "@/lib/site";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: siteConfig.name,
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web browser",
    description: siteConfig.defaultDescription,
    url: siteConfig.siteUrl,
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD"
    },
    featureList: [
      "Microsoft 365 user and group inventory",
      "License capacity and service plan analysis",
      "SharePoint and OneDrive usage reporting",
      "MFA coverage and security scoring",
      "Admin role analysis and inactive user detection",
      "CSV, JSON, Excel, and HTML exports",
      "Browser-only data collection",
      "Zero server storage"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteConfig.name,
    url: siteConfig.siteUrl,
    potentialAction: {
      "@type": "SearchAction",
      target: `${siteConfig.siteUrl}/blog?q={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: siteConfig.name,
    url: siteConfig.siteUrl,
    founder: {
      "@type": "Person",
      name: siteConfig.authorName,
      url: siteConfig.authorUrl
    },
    sameAs: organizationProfiles
  }
];
---

<BaseLayout
  title={`${siteConfig.name} | Microsoft 365 Usage, License & Security Insights`}
  description="Free browser-based Microsoft 365 reporting platform. Users, licenses, groups, SharePoint, OneDrive, MFA coverage, security scoring, and local exports — zero server storage."
  keywords={[
    ...siteConfig.defaultKeywords,
    "microsoft 365 security insights",
    "m365 mfa coverage report",
    "sharepoint usage report",
    "onedrive usage analytics",
    "m365 security score",
    "microsoft 365 admin reporting"
  ]}
  structuredData={structuredData}
>
  <HomeHero />

  <SectionBlock
    title="Sign in, collect, export — in one session"
    description="Connect with Microsoft Entra, generate reports across your entire tenant, and download clean exports. Everything runs in the browser."
  >
    <div class="grid gap-4 md:grid-cols-3">
      <article class="fine-border card-hover rounded-2xl bg-white p-6">
        <div class="icon-container bg-sky-500/10 text-sky-500 mb-4">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
            <polyline points="10 17 15 12 10 7" />
            <line x1="15" y1="12" x2="3" y2="12" />
          </svg>
        </div>
        <h3 class="text-base font-bold text-ink-950">Authenticate</h3>
        <p class="mt-2 text-sm leading-7 text-ink-600">Sign in with Microsoft Entra delegated access. Reports start collecting automatically.</p>
      </article>
      <article class="fine-border card-hover rounded-2xl bg-white p-6">
        <div class="icon-container bg-mint-500/10 text-mint-500 mb-4">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
          </svg>
        </div>
        <h3 class="text-base font-bold text-ink-950">Analyze</h3>
        <p class="mt-2 text-sm leading-7 text-ink-600">View users, licenses, usage, and security insights with interactive charts and tables.</p>
      </article>
      <article class="fine-border card-hover rounded-2xl bg-white p-6">
        <div class="icon-container bg-violet-500/10 text-violet-500 mb-4">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
        </div>
        <h3 class="text-base font-bold text-ink-950">Export</h3>
        <p class="mt-2 text-sm leading-7 text-ink-600">Download CSV, JSON, Excel, or HTML files. All data stays in your browser session.</p>
      </article>
    </div>
  </SectionBlock>

  <SectionBlock
    title="Nine reporting modules in one dashboard"
    description="From basic inventory to security scoring — everything a Microsoft 365 admin needs for tenant visibility."
  >
    <CapabilityGrid />
  </SectionBlock>

  <SectionBlock
    title="Feature guides"
    description="Step-by-step documentation for every reporting capability."
  >
    <GuidePreviewGrid />
  </SectionBlock>
</BaseLayout>
