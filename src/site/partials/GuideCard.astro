---
import type { BlogSummary } from "@/lib/blog";
import { withBase } from "@/lib/paths";

interface Props {
  guide: BlogSummary;
}

const { guide } = Astro.props;
---

<a
  href={withBase(`/blog/${guide.slug}/`)}
  class="group fine-border card-hover block rounded-2xl bg-white p-6 transition hover:border-sky-500/20"
>
  <div class="flex items-center gap-2">
    <span class="badge badge-sky text-[11px]">{guide.category}</span>
  </div>
  <h3 class="mt-4 text-lg font-bold text-ink-950 group-hover:text-sky-500 transition">{guide.title}</h3>
  <p class="mt-2 text-sm leading-7 text-ink-600">{guide.excerpt}</p>
  <div class="mt-5 flex items-center justify-between gap-3">
    <div class="flex items-center gap-1.5 text-xs font-medium text-ink-500">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      {guide.readingTime}
    </div>
    <span class="text-xs text-ink-500">{guide.publishedAt}</span>
  </div>
</a>
