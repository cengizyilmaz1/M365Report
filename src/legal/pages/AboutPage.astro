---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import SectionBlock from "@/components/site/SectionBlock.astro";
import { siteConfig } from "@/lib/site";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About | M365 Tenant Reporter",
  url: `${siteConfig.siteUrl}${siteConfig.aboutPath}`
};
---

<BaseLayout
  title="About | M365 Tenant Reporter"
  description="Learn how M365 Tenant Reporter is structured as a production-grade Microsoft 365 reporting product with a zero-storage model."
  keywords={[
    "about m365 tenant reporter",
    "microsoft 365 reporting architecture",
    "zero-storage reporting product"
  ]}
  structuredData={structuredData}
>
  <PageHero
    eyebrow="About"
    title="A focused reporting product for Microsoft 365 teams who want visibility without remediation risk."
    body="M365 Tenant Reporter is designed to be read-only, browser-first, and structurally disciplined. The product site, login surface, legal pages, and Jekyll blog are separated so the project can scale without collapsing into one folder."
  />

  <SectionBlock title="Product principles">
    <div class="grid gap-4 md:grid-cols-3">
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Read-only by design</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">The app does not assign licenses, change tenant settings, or perform remediation. It reports and exports only.</p>
      </article>
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Zero-storage mindset</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Tenant report data is collected in the browser and discarded after the active session rather than written to a server-side system.</p>
      </article>
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Open-source maintainability</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">The repo structure is meant to stay understandable as new modules, docs, and integrations are added.</p>
      </article>
    </div>
  </SectionBlock>

  <SectionBlock title="Maintainer context">
    <div class="space-y-4 text-base leading-8 text-ink-700">
      <p>The product is part of a broader Microsoft 365-focused tooling network maintained under the Cengiz Yilmaz domain ecosystem.</p>
      <p>That is why the public site links cleanly to related utilities, while the core reporting experience stays concentrated around the single hostname <strong>{siteConfig.domain}</strong>.</p>
    </div>
  </SectionBlock>
</BaseLayout>
