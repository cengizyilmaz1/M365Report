---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AppEntry from "@/features/app/AppEntry";
import { siteConfig } from "@/lib/site";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Login | M365 Tenant Reporter",
  url: `${siteConfig.siteUrl}${siteConfig.loginPath}`
};
---

<BaseLayout
  title="Login | M365 Tenant Reporter"
  description="Use the single login route to sign in with Microsoft Entra, generate a tenant report snapshot, and export the result."
  keywords={[
    "m365 tenant reporter login",
    "microsoft entra delegated login",
    "m365report login page"
  ]}
  noindex={true}
  structuredData={structuredData}
>
  <section class="section-space pb-6">
    <div class="page-frame grid gap-6 xl:grid-cols-[0.78fr_1.22fr]">
      <div class="hero-glow glass-panel rounded-[2.2rem] p-8 md:p-10">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-500">Single login route</p>
        <h1 class="mt-4 max-w-2xl text-balance text-4xl font-semibold leading-tight text-ink-950 md:text-5xl">
          Sign in, generate reports, and export from one clean page.
        </h1>
        <p class="mt-4 max-w-2xl text-base leading-8 text-ink-700">
          This is the main operational entry point for M365 Tenant Reporter. The same page handles Microsoft Entra sign-in, in-session report generation, and local exports.
        </p>

        <div class="mt-8 flex flex-wrap gap-2">
          <span class="rounded-full bg-sand-100 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-ink-700">Read-only</span>
          <span class="rounded-full bg-sand-100 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-ink-700">Session-only</span>
          <span class="rounded-full bg-sand-100 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-ink-700">Local exports</span>
        </div>
      </div>

      <div class="glass-panel rounded-[2.2rem] p-8 md:p-10">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-500">What users can do</p>
        <div class="mt-5 grid gap-4">
          <div class="fine-border rounded-[1.5rem] bg-white/92 p-5">
            <h2 class="text-lg font-semibold text-ink-950">Generate reports</h2>
            <p class="mt-2 text-sm leading-7 text-ink-700">Collect overview, users, licenses, groups, mailbox purpose, and export-ready tables directly from Microsoft Graph.</p>
          </div>
          <div class="fine-border rounded-[1.5rem] bg-white/92 p-5">
            <h2 class="text-lg font-semibold text-ink-950">Keep data in-session</h2>
            <p class="mt-2 text-sm leading-7 text-ink-700">The product is designed to avoid persistent tenant storage. Clear the session, refresh, sign out, or close the tab to remove the in-memory snapshot.</p>
          </div>
          <div class="fine-border rounded-[1.5rem] bg-white/92 p-5">
            <h2 class="text-lg font-semibold text-ink-950">Understand limits clearly</h2>
            <p class="mt-2 text-sm leading-7 text-ink-700">When a workload is unavailable because of roles, licensing, or browser-only constraints, the page shows a clear note instead of treating the whole report as failed.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6">
      <AppEntry client:load />
    </div>
  </section>
</BaseLayout>
