---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBlogSlug, sortBlogEntries, toBlogSummary } from "@/lib/blog";
import { withBase } from "@/lib/paths";
import "@/styles/blog.css";

export async function getStaticPaths() {
  const entries = sortBlogEntries(await getCollection("blog"));

  return entries.map((entry) => ({
    params: { slug: getBlogSlug(entry.id) },
    props: { entry, entries }
  }));
}

const { entry, entries } = Astro.props;
const { Content } = await render(entry);
const currentGuide = toBlogSummary(entry);
const relatedGuides = sortBlogEntries(entries)
  .filter((candidate) => candidate.id !== entry.id)
  .slice(0, 3)
  .map((candidate) => toBlogSummary(candidate));

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: currentGuide.publishedDateIso,
  author: {
    "@type": "Person",
    name: entry.data.author ?? "Cengiz Yilmaz"
  },
  publisher: {
    "@type": "Organization",
    name: "M365 Tenant Reporter"
  },
  mainEntityOfPage: `https://m365report.cengizyilmaz.net/blog/${currentGuide.slug}/`
};
---

<BaseLayout
  title={`${entry.data.title} | M365 Tenant Reporter`}
  description={entry.data.description}
  keywords={entry.data.keywords}
  pageType="article"
  canonicalPath={`/blog/${currentGuide.slug}/`}
  publishedTime={currentGuide.publishedDateIso}
  modifiedTime={currentGuide.publishedDateIso}
  structuredData={structuredData}
>
  <section class="section-space pb-4">
    <div class="page-frame">
      <a href={withBase("/blog")} class="blog-back-link">← Back to all guides</a>
    </div>
  </section>

  <section class="pb-16">
    <div class="page-frame blog-article-shell">
      <article class="glass-panel blog-article">
        <div class="flex flex-wrap gap-2">
          <span class="badge badge-sky text-[11px]">{entry.data.category}</span>
          <span class="badge badge-muted text-[11px]">{entry.data.reading_time}</span>
          <span class="badge badge-muted text-[11px]">{currentGuide.publishedAt}</span>
        </div>

        <h1 class="mt-5 max-w-4xl text-balance text-4xl font-semibold leading-tight text-ink-950 md:text-5xl">
          {entry.data.title}
        </h1>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-ink-700">{entry.data.description}</p>

        <div class="blog-prose mt-10">
          <Content />
        </div>
      </article>

      <aside class="blog-sidebar">
        <section class="glass-panel rounded-[2rem] p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-500">Run the product</p>
          <h2 class="mt-3 text-2xl font-semibold text-ink-950">{entry.data.cta_title ?? "Generate a live tenant snapshot"}</h2>
          <p class="mt-3 text-sm leading-7 text-ink-700">
            {entry.data.cta_body ?? "Sign in with Microsoft Entra, collect the current tenant data in your browser, and export the results locally."}
          </p>
          <a
            href={withBase("/login")}
            class="mt-6 inline-flex items-center justify-center rounded-full bg-ink-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-ink-800"
          >
            Open login
          </a>
        </section>

        <section class="glass-panel rounded-[2rem] p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-500">More guides</p>
          <div class="mt-4 grid gap-3">
            {relatedGuides.map((guide) => (
              <a href={withBase(`/blog/${guide.slug}/`)} class="blog-related-card">
                <span class="badge badge-muted text-[11px]">{guide.category}</span>
                <h3 class="mt-3 text-base font-semibold text-ink-950">{guide.title}</h3>
                <p class="mt-2 text-sm leading-7 text-ink-700">{guide.excerpt}</p>
              </a>
            ))}
          </div>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
