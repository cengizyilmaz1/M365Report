---
import { headerActions, siteConfig, siteNavigation } from "@/lib/site";
import { resolveHref, withBase } from "@/lib/paths";

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
---

<header class="sticky top-0 z-50 pt-4">
  <div class="page-frame">
    <div class="glass-panel rounded-[1.75rem] px-5 py-4 md:px-6">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <a href={withBase("/")} class="flex items-center gap-4">
          <span class="flex h-11 w-11 items-center justify-center rounded-[1rem] bg-linear-to-br from-sky-400/85 to-ink-900 text-sm font-bold uppercase tracking-[0.16em] text-white shadow-lg">
            M
          </span>
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-ink-950">{siteConfig.name}</p>
            <p class="mt-1 text-xs text-ink-600">Read-only tenant reporting for Microsoft 365</p>
          </div>
        </a>

        <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:gap-4">
          <nav class="flex flex-wrap items-center gap-2">
            {siteNavigation.map((item) => {
              const normalizedItemHref = item.href.replace(/\/+$/, "") || "/";
              const isActive =
                normalizedItemHref === "/" ? currentPath === "/" : currentPath.startsWith(normalizedItemHref);

              return (
                <a
                  href={resolveHref(item)}
                  class:list={[
                    "rounded-full px-4 py-2 text-sm font-semibold transition",
                    isActive
                      ? "bg-ink-900 text-white shadow-sm"
                      : "text-ink-700 hover:bg-white hover:text-ink-950"
                  ]}
                >
                  {item.label}
                </a>
              );
            })}
          </nav>

          <div class="flex flex-wrap items-center gap-3">
            {headerActions.map((item) => (
              <a
                href={resolveHref(item)}
                class:list={[
                  "rounded-full px-4 py-2.5 text-sm font-semibold transition shadow-sm",
                  item.tone === "primary" && "bg-ink-900 text-white hover:-translate-y-0.5 hover:bg-ink-800",
                  item.tone === "secondary" &&
                    "border border-ink-900/10 bg-white/90 text-ink-800 hover:-translate-y-0.5 hover:border-ink-900/25 hover:bg-white"
                ]}
                title={item.description}
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
