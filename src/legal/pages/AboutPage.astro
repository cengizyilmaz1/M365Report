---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import SectionBlock from "@/components/site/SectionBlock.astro";
import { siteConfig } from "@/lib/site";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About | M365 Tenant Reporter",
  url: `${siteConfig.siteUrl}${siteConfig.aboutPath}`
};
---

<BaseLayout
  title="About | M365 Tenant Reporter"
  description="Learn what M365 Tenant Reporter does, who it is for, and why it keeps Microsoft 365 reporting read-only and session-based."
  keywords={[
    "about m365 tenant reporter",
    "microsoft 365 reporting architecture",
    "zero-storage reporting product"
  ]}
  structuredData={structuredData}
>
  <PageHero
    eyebrow="About"
    title="A focused reporting product for Microsoft 365 teams."
    body="M365 Tenant Reporter is built for visibility, not remediation. Sign in, collect a report snapshot, review the data, and export what you need."
  />

  <SectionBlock title="What the product does">
    <div class="grid gap-4 md:grid-cols-3">
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Inventory reporting</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Review total users, licensed users, unlicensed users, groups, mailbox purpose, and license capacity.</p>
      </article>
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Local exports</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Download report outputs as CSV, JSON, Excel, or HTML directly from the browser.</p>
      </article>
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Read-only safety</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">The app does not assign licenses, change tenant settings, or run remediation actions.</p>
      </article>
    </div>
  </SectionBlock>

  <SectionBlock title="How the product is meant to be used">
    <div class="space-y-4 text-base leading-8 text-ink-700">
      <p>The main user flow is simple: open <strong>{`${siteConfig.domain}/login`}</strong>, complete Microsoft Entra sign-in, generate a fresh report snapshot, then export what you need.</p>
      <p>The public site and blog explain the product, but the operational experience is centered around that single login route so it stays clear for admins and end users.</p>
    </div>
  </SectionBlock>
</BaseLayout>
