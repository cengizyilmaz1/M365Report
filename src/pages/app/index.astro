---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/lib/paths";
---

<BaseLayout
  title="Redirecting to Login | M365 Tenant Reporter"
  description="The reporting experience now lives directly on the login page."
  noindex={true}
>
  <section class="section-space">
    <div class="page-frame">
      <div class="glass-panel rounded-[2rem] px-6 py-16 text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-500">Route updated</p>
        <h1 class="mt-4 text-4xl font-semibold text-ink-950">The reporting flow now starts at /login.</h1>
        <p class="mx-auto mt-4 max-w-xl text-base leading-8 text-ink-700">
          You are being redirected to the main sign-in and reporting page.
        </p>
        <div class="mt-8 flex justify-center">
          <a href={withBase("/login")} class="rounded-full bg-ink-900 px-5 py-3 text-sm font-semibold text-white">Go to login</a>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    window.location.replace(`${withBase("/login")}`);
  </script>
</BaseLayout>
