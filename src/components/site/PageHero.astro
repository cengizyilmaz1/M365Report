---
import { withBase } from "@/lib/paths";
import { siteConfig } from "@/lib/site";

interface Props {
  eyebrow: string;
  title: string;
  body: string;
}

const { eyebrow, title, body } = Astro.props;
---

<section class="section-space pb-4">
  <div class="page-frame">
    <div class="hero-glow glass-panel rounded-3xl px-6 py-10 md:px-10 md:py-14">
      <div class="max-w-4xl space-y-5 animate-fade-up">
        <span class="badge badge-sky">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
          {eyebrow}
        </span>

        <h1 class="max-w-3xl text-balance text-4xl font-bold leading-tight tracking-tight text-ink-950 md:text-5xl" style="font-family: var(--font-display);">
          {title}
        </h1>

        <p class="max-w-3xl text-lg leading-8 text-ink-600">{body}</p>

        <div class="flex flex-wrap items-center gap-3 pt-1">
          <a href={withBase(siteConfig.loginPath)} class="btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
              <polyline points="10 17 15 12 10 7" />
              <line x1="15" y1="12" x2="3" y2="12" />
            </svg>
            Sign in
          </a>
          <a href={withBase(siteConfig.blogPath)} class="btn-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
            </svg>
            Read guides
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
