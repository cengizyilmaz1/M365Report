---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import SectionBlock from "@/components/site/SectionBlock.astro";
import { withBase } from "@/lib/paths";
import { siteConfig } from "@/lib/site";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "Deploy and start using M365 Tenant Reporter",
    description:
      "Create a public client app registration, materialize runtime configuration, deploy to GitHub Pages, and sign in through the production login page.",
    step: [
      {
        "@type": "HowToStep",
        name: "Create a Microsoft Entra public client app registration"
      },
      {
        "@type": "HowToStep",
        name: "Configure redirect URIs and repository variables"
      },
      {
        "@type": "HowToStep",
        name: "Deploy the Astro site to GitHub Pages"
      },
      {
        "@type": "HowToStep",
        name: "Open the login page and grant consent"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Overview",
        item: siteConfig.siteUrl
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Docs",
        item: `${siteConfig.siteUrl}/docs/getting-started`
      }
    ]
  }
];
---

<BaseLayout
  title="Getting Started | M365 Tenant Reporter"
  description="Deployment and runtime configuration guidance for self-hosting M365 Tenant Reporter."
  keywords={[
    "m365 tenant reporter deployment",
    "github pages microsoft graph app",
    "m365 runtime configuration"
  ]}
  structuredData={structuredData}
>
  <PageHero
    eyebrow="Deployment guide"
    title="Prepare a public client configuration, deploy to GitHub Pages, and sign in with a Microsoft 365 tenant."
    body="The repository ships with a public runtime configuration model so you can host the static app without embedding confidential secrets in the browser bundle."
  />

  <SectionBlock title="Implementation checklist">
    <ol class="space-y-4 text-base leading-8 text-ink-700">
      <li>1. Create or reuse a multi-tenant public client app registration in Microsoft Entra ID.</li>
      <li>2. Configure redirect URIs for your GitHub Pages hostname and the dedicated login route.</li>
      <li>3. Set repository variables for the public runtime configuration and let the deploy workflow materialize <code>runtime-config.json</code>.</li>
      <li>4. Review the permissions page before granting admin consent in production.</li>
    </ol>
  </SectionBlock>

  <SectionBlock title="Recommended production URLs">
    <div class="grid gap-4 md:grid-cols-2">
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">Public site</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">
          The primary hostname is <strong>{siteConfig.domain}</strong>. Public overview, feature, security, blog, and documentation pages should live there.
        </p>
      </article>
      <article class="fine-border rounded-[1.5rem] bg-white p-6">
        <h3 class="text-lg font-semibold text-ink-950">User sign-in entry point</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">
          Direct users to <strong>{siteConfig.domain}/login</strong> so they start from the consent-aware login page instead of deep-linking into the app.
        </p>
      </article>
    </div>
  </SectionBlock>

  <SectionBlock title="Continue reading">
    <div class="grid gap-4 md:grid-cols-3">
      <a href={withBase("/docs/permissions")} class="fine-border rounded-[1.5rem] bg-white p-6 transition hover:border-ink-900/16 hover:bg-sand-100">
        <h3 class="text-lg font-semibold text-ink-950">Permission model</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Review the delegated Graph scopes required for each module.</p>
      </a>
      <a href={withBase("/blog/connect-your-microsoft-365-tenant")} class="fine-border rounded-[1.5rem] bg-white p-6 transition hover:border-ink-900/16 hover:bg-sand-100">
        <h3 class="text-lg font-semibold text-ink-950">Login walkthrough</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">See the full sign-in and consent journey from the user perspective.</p>
      </a>
      <a href={withBase(siteConfig.loginPath)} class="fine-border rounded-[1.5rem] bg-white p-6 transition hover:border-ink-900/16 hover:bg-sand-100">
        <h3 class="text-lg font-semibold text-ink-950">Open the live login page</h3>
        <p class="mt-3 text-sm leading-7 text-ink-700">Launch the production sign-in flow and start a browser-only reporting session.</p>
      </a>
    </div>
  </SectionBlock>
</BaseLayout>
