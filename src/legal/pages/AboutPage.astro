---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/lib/paths";
import { siteConfig } from "@/lib/site";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About | M365 Tenant Reporter",
  url: `${siteConfig.siteUrl}${siteConfig.aboutPath}`,
  description: "Microsoft 365 usage, license, and security insights platform. Browser-only. Zero storage."
};
---

<BaseLayout
  title="About | M365 Tenant Reporter"
  description="M365 Tenant Reporter is a free Microsoft 365 reporting platform for usage analytics, license insights, and security scoring — entirely in the browser."
  keywords={["about m365 tenant reporter", "microsoft 365 reporting platform", "zero-storage reporting", "m365 security insights"]}
  structuredData={structuredData}
>
  <section class="section-space">
    <div class="page-frame max-w-4xl">
      <div class="glass-panel rounded-3xl p-8 md:p-12 animate-fade-up">
        <span class="badge badge-sky mb-6">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="16" x2="12" y2="12" />
            <line x1="12" y1="8" x2="12.01" y2="8" />
          </svg>
          About
        </span>

        <h1 class="text-3xl font-bold tracking-tight text-ink-950 md:text-4xl" style="font-family: var(--font-display);">
          Microsoft 365 insights platform — free, browser-only, zero storage.
        </h1>

        <div class="mt-8 space-y-5 text-base leading-8 text-ink-600">
          <p>
            M365 Tenant Reporter gives Microsoft 365 administrators complete tenant visibility from a single browser session. It connects directly to Microsoft Graph using delegated permissions and collects users, licenses, groups, mailboxes, SharePoint sites, OneDrive accounts, activity reports, and security insights — without storing anything on a server.
          </p>
          <p>
            The platform includes a composite security score based on MFA coverage, inactive users, guest risk, and admin role analysis. All data is processed in the browser and exported locally as CSV, JSON, Excel, or HTML.
          </p>
        </div>

        <div class="divider my-8"></div>

        <div class="grid gap-6 sm:grid-cols-3 lg:grid-cols-5">
          <div class="text-center">
            <p class="text-3xl font-bold text-ink-950">9</p>
            <p class="mt-1 text-sm text-ink-600">Report modules</p>
          </div>
          <div class="text-center">
            <p class="text-3xl font-bold text-ink-950">4</p>
            <p class="mt-1 text-sm text-ink-600">Export formats</p>
          </div>
          <div class="text-center">
            <p class="text-3xl font-bold text-ink-950">0</p>
            <p class="mt-1 text-sm text-ink-600">Server storage</p>
          </div>
          <div class="text-center">
            <p class="text-3xl font-bold text-ink-950">100</p>
            <p class="mt-1 text-sm text-ink-600">Security score max</p>
          </div>
          <div class="text-center">
            <p class="text-3xl font-bold text-ink-950">Free</p>
            <p class="mt-1 text-sm text-ink-600">No subscription</p>
          </div>
        </div>

        <div class="divider my-8"></div>

        <h2 class="text-xl font-bold text-ink-950 mb-4">What's included</h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {[
            { title: "User & Group Inventory", desc: "Complete user listing with license assignments, group memberships, and mailbox types." },
            { title: "License & Service Plan Analysis", desc: "SKU capacity, service plan assignments, and detection of partially enabled licenses." },
            { title: "SharePoint & OneDrive Usage", desc: "Site activity levels, storage consumption, and active vs inactive account detection." },
            { title: "Security & MFA Insights", desc: "MFA registration, inactive users, guest risk, admin roles, and a 0–100 security score." },
            { title: "Activity Reports", desc: "Office 365, Teams, Mailbox, and OneDrive usage reports from Microsoft Graph." },
            { title: "Multi-format Exports", desc: "Download any dataset as CSV, JSON, Excel, or standalone HTML." }
          ].map((item) => (
            <div class="flex items-start gap-3 rounded-xl border border-ink-900/6 bg-white p-4">
              <div class="icon-container bg-sky-500/10 text-sky-500 shrink-0 mt-0.5">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-ink-950">{item.title}</p>
                <p class="mt-1 text-sm text-ink-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="divider my-8"></div>

        <div class="flex flex-wrap gap-3">
          <a href={withBase("/app")} class="btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>
            Open dashboard
          </a>
          <a href={withBase("/blog")} class="btn-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" /><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" /></svg>
            Read guides
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
