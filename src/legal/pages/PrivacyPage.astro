---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/lib/site";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Privacy | M365 Tenant Reporter",
  url: `${siteConfig.siteUrl}${siteConfig.privacyPath}`,
  description: "Zero-storage privacy model. Browser-only data collection."
};
---

<BaseLayout
  title="Privacy | M365 Tenant Reporter"
  description="M365 Tenant Reporter does not store tenant data. All collection happens in the browser and stays in the current session."
  keywords={["m365 privacy", "zero-storage reporting", "browser-only data collection"]}
  structuredData={structuredData}
>
  <section class="section-space">
    <div class="page-frame max-w-3xl">
      <div class="glass-panel rounded-3xl p-8 md:p-12 animate-fade-up">
        <span class="badge badge-mint mb-6">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
          </svg>
          Privacy
        </span>

        <h1 class="text-3xl font-bold tracking-tight text-ink-950 md:text-4xl" style="font-family: var(--font-display);">
          Your tenant data never leaves the browser.
        </h1>

        <div class="mt-8 space-y-6">
          <div class="flex items-start gap-4">
            <div class="icon-container bg-mint-500/10 text-mint-500 shrink-0 mt-1">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>
            <div>
              <h2 class="text-base font-bold text-ink-950">Browser-only collection</h2>
              <p class="mt-1 text-sm leading-7 text-ink-600">Microsoft Graph data is fetched directly from your browser after delegated sign-in. No proxy, no backend.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="icon-container bg-mint-500/10 text-mint-500 shrink-0 mt-1">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>
            <div>
              <h2 class="text-base font-bold text-ink-950">Session-only storage</h2>
              <p class="mt-1 text-sm leading-7 text-ink-600">Report data lives in memory. Close the tab, refresh, or sign out to remove everything.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="icon-container bg-mint-500/10 text-mint-500 shrink-0 mt-1">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>
            <div>
              <h2 class="text-base font-bold text-ink-950">Local exports</h2>
              <p class="mt-1 text-sm leading-7 text-ink-600">CSV, JSON, Excel, and HTML files are generated locally and downloaded to your device. Nothing is uploaded back.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="icon-container bg-mint-500/10 text-mint-500 shrink-0 mt-1">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>
            <div>
              <h2 class="text-base font-bold text-ink-950">No server-side database</h2>
              <p class="mt-1 text-sm leading-7 text-ink-600">Users, groups, licenses, and activity rows are not stored in any backend database.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
