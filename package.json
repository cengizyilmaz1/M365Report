{
  "name": "m365-tenant-reporter",
  "version": "0.1.0",
  "private": true,
  "description": "Zero-storage Microsoft 365 tenant reporting app for GitHub Pages.",
  "type": "module",
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "sync:shared": "node ./scripts/sync-shared-assets.mjs",
    "dev": "npm run sync:shared && astro dev",
    "dev:site": "npm run sync:shared && astro dev",
    "dev:blog": "npm run sync:shared && node ./scripts/dev-jekyll-blog.mjs",
    "start": "npm run dev",
    "build:site": "npm run sync:shared && astro build",
    "blog:install": "npm run sync:shared && node ./scripts/install-jekyll-deps.mjs",
    "build:blog": "npm run sync:shared && node ./scripts/build-jekyll-blog.mjs",
    "build": "npm run build:site && npm run build:blog",
    "preview": "node ./scripts/serve-dist.mjs",
    "typecheck": "astro check",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "validate:config": "node ./scripts/validate-runtime-config.mjs ./public/runtime-config.json",
    "validate:config:strict": "node ./scripts/validate-runtime-config.mjs ./public/runtime-config.json --strict",
    "config:materialize": "node ./scripts/materialize-runtime-config.mjs ./public/runtime-config.json",
    "ci": "npm run validate:config && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@astrojs/react": "5.0.2",
    "@astrojs/sitemap": "3.7.2",
    "@azure/msal-browser": "5.6.2",
    "@radix-ui/react-dialog": "1.1.15",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-table": "8.21.3",
    "astro": "6.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.4.1",
    "xlsx": "0.18.5",
    "zod": "4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.58.2",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "jsdom": "29.0.1",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  }
}
