---
import type { GuideSummary } from "@/lib/guides";
import { withBase } from "@/lib/paths";

interface Props {
  guide: GuideSummary;
}

const { guide } = Astro.props;
---

<a
  href={withBase(`/blog/${guide.slug}/`)}
  class="fine-border card-hover block rounded-[1.5rem] bg-white p-6 transition hover:border-ink-900/16 hover:bg-sand-100"
>
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-500">{guide.category}</p>
  <h3 class="mt-4 text-xl font-semibold text-ink-950">{guide.title}</h3>
  <p class="mt-3 text-sm leading-7 text-ink-700">{guide.excerpt}</p>
  <div class="mt-5 flex items-center justify-between gap-3 text-xs font-semibold uppercase tracking-[0.16em] text-ink-700">
    <span>{guide.readingTime}</span>
    <span>{guide.publishedAt}</span>
  </div>
</a>
