---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/lib/paths";
import { siteConfig } from "@/lib/site";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About | M365 Tenant Reporter",
  url: `${siteConfig.siteUrl}${siteConfig.aboutPath}`,
  description: "Read-only Microsoft 365 tenant reporting. Browser-only. Zero storage."
};
---

<BaseLayout
  title="About | M365 Tenant Reporter"
  description="M365 Tenant Reporter is a read-only Microsoft 365 reporting tool with browser-only data collection and local exports."
  keywords={["about m365 tenant reporter", "microsoft 365 reporting", "zero-storage reporting"]}
  structuredData={structuredData}
>
  <section class="section-space">
    <div class="page-frame max-w-3xl">
      <div class="glass-panel rounded-3xl p-8 md:p-12 animate-fade-up">
        <span class="badge badge-sky mb-6">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="16" x2="12" y2="12" />
            <line x1="12" y1="8" x2="12.01" y2="8" />
          </svg>
          About
        </span>

        <h1 class="text-3xl font-bold tracking-tight text-ink-950 md:text-4xl" style="font-family: var(--font-display);">
          Read-only reporting for Microsoft 365.
        </h1>

        <div class="mt-6 space-y-4 text-base leading-8 text-ink-600">
          <p>
            M365 Tenant Reporter collects users, licenses, groups, mailbox data, and activity reports from Microsoft Graph — entirely in the browser. No data is stored on any server.
          </p>
          <p>
            Export to CSV, JSON, Excel, or HTML. Reports stay in your browser session and disappear when you close the tab.
          </p>
        </div>

        <div class="divider my-8"></div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div class="text-center">
            <p class="text-2xl font-bold text-ink-950">6</p>
            <p class="mt-1 text-sm text-ink-600">Report modules</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-ink-950">4</p>
            <p class="mt-1 text-sm text-ink-600">Export formats</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-ink-950">0</p>
            <p class="mt-1 text-sm text-ink-600">Server storage</p>
          </div>
        </div>

        <div class="divider my-8"></div>

        <div class="flex flex-wrap gap-3">
          <a href={withBase("/app")} class="btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
            </svg>
            Open app
          </a>
          <a href={withBase("/blog")} class="btn-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
            </svg>
            Read guides
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
