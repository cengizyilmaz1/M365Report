---
import { withBase } from "@/lib/paths";
import { siteConfig } from "@/lib/site";

interface Props {
  eyebrow: string;
  title: string;
  body: string;
}

const { eyebrow, title, body } = Astro.props;
---

<section class="section-space pb-6">
  <div class="page-frame">
    <div class="hero-glow glass-panel rounded-[2.2rem] px-6 py-8 md:px-10 md:py-10">
      <div class="grid gap-8 xl:grid-cols-[1.28fr_0.72fr] xl:items-start">
        <div class="space-y-5">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-500">{eyebrow}</p>
          <h1 class="max-w-3xl text-balance text-4xl font-semibold leading-tight text-ink-950 md:text-5xl">{title}</h1>
          <p class="max-w-3xl text-lg leading-8 text-ink-700">{body}</p>

          <div class="flex flex-wrap gap-3 pt-2">
            <a
              href={withBase(siteConfig.loginPath)}
              class="rounded-full bg-ink-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-ink-800"
            >
              Open login
            </a>
            <a
              href={withBase(siteConfig.blogPath)}
              class="rounded-full border border-ink-900/10 bg-white/90 px-4 py-2.5 text-sm font-semibold text-ink-800 transition hover:-translate-y-0.5 hover:border-ink-900/25"
            >
              Browse guides
            </a>
          </div>
        </div>

        <div class="grid gap-4">
          <div class="fine-border rounded-[1.6rem] bg-white/90 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-500">Route discipline</p>
            <p class="mt-3 text-sm leading-7 text-ink-700">
              Public site content, delegated sign-in, and SEO documentation stay clearly separated for cleaner maintenance.
            </p>
          </div>
          <div class="grid gap-3 md:grid-cols-3 xl:grid-cols-1">
            <div class="fine-border rounded-[1.4rem] bg-white/90 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-600">Main site</p>
              <p class="mt-2 text-sm font-semibold text-ink-950">{siteConfig.domain}</p>
            </div>
            <div class="fine-border rounded-[1.4rem] bg-white/90 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-600">Login</p>
              <p class="mt-2 text-sm font-semibold text-ink-950">{`${siteConfig.domain}/login`}</p>
            </div>
            <div class="fine-border rounded-[1.4rem] bg-white/90 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-600">Blog</p>
              <p class="mt-2 text-sm font-semibold text-ink-950">{`${siteConfig.domain}/blog`}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
